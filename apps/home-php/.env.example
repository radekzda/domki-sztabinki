APP_NAME="Domki Sztabinki PMS"
APP_ENV="production"
APP_DEBUG="false"
APP_URL="https://admin.domkisztabinki.pl"
APP_TIMEZONE="Europe/Warsaw"

DB_HOST="localhost"
DB_PORT="3306"
DB_DATABASE="CHANGE_ME_DATABASE"
DB_USERNAME="CHANGE_ME_USERNAME"
DB_PASSWORD="CHANGE_ME_PASSWORD"
DB_CHARSET="utf8mb4"

# Dane używane wyłącznie do utworzenia pierwszego Administratora
# przez bin/users-migrate.php. Po migracji logowanie korzysta z tabeli users.
ADMIN_EMAIL="admin@example.com"
# Zalecane: hash wygenerowany przez password_hash().
ADMIN_PASSWORD_HASH=""
# Przejściowa zgodność lokalna. Po migracji pozostaw puste.
ADMIN_PASSWORD="CHANGE_ME_STRONG_PASSWORD"

MAIL_ENABLED="false"
MAIL_FROM_EMAIL="radekzdancewicz@gmail.com"
MAIL_FROM_NAME="Domki Sztabinki"

# Jednorazowy link odzyskiwania hasła
PASSWORD_RESET_TTL_MINUTES="30"

# SMTP wymagane do wysyłki linków odzyskiwania hasła
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_ENCRYPTION="tls"
SMTP_USERNAME=""
SMTP_PASSWORD=""
