# Domki Sztabinki PMS
# Security: uploaded files must never execute as PHP scripts.

<FilesMatch "\.(php|php[0-9]?|phtml|phar|shtml|cgi|pl|py|sh)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>

    <IfModule !mod_authz_core.c>
        Deny from all
    </IfModule>
</FilesMatch>

<FilesMatch "\.(htaccess|htpasswd|ini|log|sql|env|bak|backup|old|orig|save|swp)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>

    <IfModule !mod_authz_core.c>
        Deny from all
    </IfModule>
</FilesMatch>
