# PostgreSQL / Neon
# Przykład:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# Publiczny adres aplikacji po wdrożeniu.
# Na lokalnym komputerze może zostać:
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Logowanie administratora
# Prawdziwe wartości wpisz tylko w lokalnym pliku .env oraz później w panelu hostingu.
# Nigdy nie wpisuj prawdziwego hasła ani sekretu do .env.example.

ADMIN_PASSWORD="CHANGE_ME_STRONG_PASSWORD"
